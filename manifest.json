{
  "manifest_version": 3,
  "name": "Jay New Tab Dashboard",
  "description": "A full-screen animated new tab with glass UI, live browser audio, calendar, shortcuts, and progress widgets.",
  "version": "1.0.1",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "focus-new-tab@example.com",
      "strict_min_version": "109.0"
    }
  }
}
