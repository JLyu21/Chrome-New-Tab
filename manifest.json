{
  "manifest_version": 3,
  "name": "Jay New Tab Dashboard",
  "description": "A full-screen customizable new tab with sports, calendar, app shortcuts, and animated backgrounds.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "host_permissions": [
    "https://site.api.espn.com/*",
    "https://api.open-meteo.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "focus-new-tab@example.com",
      "strict_min_version": "109.0"
    }
  }
}
